<Window x:Class="ClamHub.ExclusionsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Scan exclusions" Height="495" Width="930"
        MinHeight="360" MinWidth="720"
        WindowStartupLocation="CenterOwner" WindowStyle="None" ResizeMode="CanResize"
        Background="{StaticResource BgBrush}">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="36" ResizeBorderThickness="6"
                            CornerRadius="0" GlassFrameThickness="0"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Border BorderBrush="{StaticResource WindowBorderBrush}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Grid Grid.Row="0" Background="{StaticResource TitleBarBrush}">
                <TextBlock x:Name="HeaderText" Text="Scan exclusions" FontWeight="SemiBold"
                           VerticalAlignment="Center" Margin="14,0,0,0"/>
                <Button HorizontalAlignment="Right" Style="{StaticResource CloseCaptionButton}"
                        Click="Cancel_Click" ToolTip="Close without saving"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Path Data="M0,0 L10,10 M0,10 L10,0" Stroke="{StaticResource TextBrush}"
                          StrokeThickness="1"/>
                </Button>
            </Grid>

            <!-- Three columns: directories, files and extensions -->
            <Grid Grid.Row="1" Margin="20,16,20,8" AllowDrop="True"
                  PreviewDragOver="Content_DragOver" Drop="Content_Drop">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" x:Name="SubtitleText" TextWrapping="Wrap"
                           Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,12"/>
                <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Directories -->
                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Excluded directories" FontWeight="SemiBold"
                               Margin="0,0,0,8"/>
                    <Border Grid.Row="1" Background="{StaticResource PanelBrush}" CornerRadius="6"
                            Padding="2">
                        <ListBox x:Name="DirList" Background="Transparent" BorderThickness="0"
                                 Foreground="{StaticResource TextBrush}"
                                 ScrollViewer.HorizontalScrollBarVisibility="Auto">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="HorizontalAlignment" Value="Left"/>
                                </Style>
                            </ListBox.ItemContainerStyle>
                        </ListBox>
                    </Border>
                    <StackPanel Grid.Row="2" Margin="0,8,0,0">
                        <Button Content="Add folder..." Height="28" HorizontalAlignment="Left"
                                Click="AddFolder_Click"/>
                        <WrapPanel Margin="0,6,0,0">
                            <Button Content="Remove selected" Height="28" Margin="0,0,6,6"
                                    Click="RemoveDir_Click"/>
                            <Button Content="Remove all" Height="28" Margin="0,0,0,6"
                                    Click="RemoveAllDir_Click"/>
                        </WrapPanel>
                    </StackPanel>
                </Grid>

                <!-- Files -->
                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Excluded files" FontWeight="SemiBold"
                               Margin="0,0,0,8"/>
                    <Border Grid.Row="1" Background="{StaticResource PanelBrush}" CornerRadius="6"
                            Padding="2">
                        <ListBox x:Name="FileList" Background="Transparent" BorderThickness="0"
                                 Foreground="{StaticResource TextBrush}"
                                 ScrollViewer.HorizontalScrollBarVisibility="Auto">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="HorizontalAlignment" Value="Left"/>
                                </Style>
                            </ListBox.ItemContainerStyle>
                        </ListBox>
                    </Border>
                    <StackPanel Grid.Row="2" Margin="0,8,0,0">
                        <Button Content="Add file..." Height="28" HorizontalAlignment="Left"
                                Click="AddFile_Click"/>
                        <WrapPanel Margin="0,6,0,0">
                            <Button Content="Remove selected" Height="28" Margin="0,0,6,6"
                                    Click="RemoveFile_Click"/>
                            <Button Content="Remove all" Height="28" Margin="0,0,0,6"
                                    Click="RemoveAllFile_Click"/>
                        </WrapPanel>
                    </StackPanel>
                </Grid>

                <!-- Extensions -->
                <Grid Grid.Column="4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Excluded file extensions" FontWeight="SemiBold"
                               Margin="0,0,0,8"/>
                    <Border Grid.Row="1" Background="{StaticResource PanelBrush}" CornerRadius="6"
                            Padding="2">
                        <ListBox x:Name="ExtList" Background="Transparent" BorderThickness="0"
                                 Foreground="{StaticResource TextBrush}"
                                 ScrollViewer.HorizontalScrollBarVisibility="Auto">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="HorizontalAlignment" Value="Left"/>
                                </Style>
                            </ListBox.ItemContainerStyle>
                        </ListBox>
                    </Border>
                    <StackPanel Grid.Row="2" Margin="0,8,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid Grid.Column="0">
                                <TextBox x:Name="ExtBox" Height="28" VerticalContentAlignment="Center"
                                         KeyDown="ExtBox_KeyDown"/>
                                <TextBlock Style="{StaticResource PlaceholderText}"
                                           Text="e.g. iso, mp4, mkv">
                                    <TextBlock.Visibility>
                                        <Binding ElementName="ExtBox" Path="Text.IsEmpty">
                                            <Binding.Converter>
                                                <BooleanToVisibilityConverter/>
                                            </Binding.Converter>
                                        </Binding>
                                    </TextBlock.Visibility>
                                </TextBlock>
                            </Grid>
                            <Button Grid.Column="1" Content="Add" Height="28" Width="60"
                                    Margin="6,0,0,0" Click="AddExt_Click"/>
                        </Grid>
                        <WrapPanel Margin="0,6,0,0">
                            <Button Content="Remove selected" Height="28" Margin="0,0,6,6"
                                    Click="RemoveExt_Click"/>
                            <Button Content="Remove all" Height="28" Margin="0,0,0,6"
                                    Click="RemoveAllExt_Click"/>
                        </WrapPanel>
                    </StackPanel>
                </Grid>
                </Grid>
            </Grid>

            <!-- Footer: status note and action buttons -->
            <Grid Grid.Row="2" Margin="20,4,20,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" x:Name="StatusText" VerticalAlignment="Center"
                           TextWrapping="Wrap" Margin="0,0,12,0"
                           Foreground="{StaticResource MutedTextBrush}"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="Cancel" Width="90" Height="32" Margin="0,0,10,0"
                            Click="Cancel_Click"/>
                    <Button Content="Save" Width="110" Height="32" FontWeight="SemiBold"
                            Click="Save_Click"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
