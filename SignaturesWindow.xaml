<Window x:Class="ClamHub.SignaturesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Custom signatures" Height="600" Width="940"
        MinHeight="440" MinWidth="720"
        WindowStartupLocation="CenterOwner" WindowStyle="None" ResizeMode="CanResize"
        Background="{StaticResource BgBrush}">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="36" ResizeBorderThickness="6"
                            CornerRadius="0" GlassFrameThickness="0"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Border BorderBrush="{StaticResource WindowBorderBrush}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Grid Grid.Row="0" Background="{StaticResource TitleBarBrush}">
                <TextBlock Text="Custom signatures" FontWeight="SemiBold"
                           VerticalAlignment="Center" Margin="14,0,0,0"/>
                <Button HorizontalAlignment="Right" Style="{StaticResource CloseCaptionButton}"
                        Click="Close_Click" ToolTip="Close"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Path Data="M0,0 L10,10 M0,10 L10,0" Stroke="{StaticResource TextBrush}"
                          StrokeThickness="1"/>
                </Button>
            </Grid>

            <!-- Content: two independent lists side by side, each its own drop target -->
            <Grid Grid.Row="1" Margin="20,14,20,8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" TextWrapping="Wrap"
                           Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,12"
                           Text="Blacklist makes scans DETECT the listed files; whitelist makes scans IGNORE them. Drop files onto a list or use its 'Add files' button. A file cannot be on both lists. Changes reload the daemon automatically."/>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Blacklist -->
                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" x:Name="BlacklistHeader" Text="Blacklist"
                                   FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <Border Grid.Row="1" Background="{StaticResource PanelBrush}" CornerRadius="6"
                                Padding="2" AllowDrop="True"
                                PreviewDragOver="List_DragOver" PreviewDrop="BlacklistBox_Drop">
                            <ListBox x:Name="BlacklistBox" Background="Transparent" BorderThickness="0"
                                     Foreground="{StaticResource TextBrush}" SelectionMode="Extended"
                                     ScrollViewer.HorizontalScrollBarVisibility="Auto">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="HorizontalAlignment" Value="Left"/>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                            </ListBox>
                        </Border>
                        <WrapPanel Grid.Row="2" Margin="0,8,0,0">
                            <Button Content="Add Files..." Height="28" Margin="0,0,6,6"
                                    Click="AddBlacklist_Click"/>
                            <Button Content="Remove Selected" Height="28" Margin="0,0,6,6"
                                    Click="RemoveBlacklist_Click"/>
                            <Button Content="Remove All" Height="28" Margin="0,0,0,6"
                                    Click="RemoveAllBlacklist_Click"/>
                        </WrapPanel>
                    </Grid>

                    <!-- Whitelist -->
                    <Grid Grid.Column="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" x:Name="WhitelistHeader" Text="Whitelist"
                                   FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <Border Grid.Row="1" Background="{StaticResource PanelBrush}" CornerRadius="6"
                                Padding="2" AllowDrop="True"
                                PreviewDragOver="List_DragOver" PreviewDrop="WhitelistBox_Drop">
                            <ListBox x:Name="WhitelistBox" Background="Transparent" BorderThickness="0"
                                     Foreground="{StaticResource TextBrush}" SelectionMode="Extended"
                                     ScrollViewer.HorizontalScrollBarVisibility="Auto">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="HorizontalAlignment" Value="Left"/>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                            </ListBox>
                        </Border>
                        <WrapPanel Grid.Row="2" Margin="0,8,0,0">
                            <Button Content="Add Files..." Height="28" Margin="0,0,6,6"
                                    Click="AddWhitelist_Click"/>
                            <Button Content="Remove Selected" Height="28" Margin="0,0,6,6"
                                    Click="RemoveWhitelist_Click"/>
                            <Button Content="Remove All" Height="28" Margin="0,0,0,6"
                                    Click="RemoveAllWhitelist_Click"/>
                        </WrapPanel>
                    </Grid>
                </Grid>
            </Grid>

            <!-- Footer: status, working bar and close -->
            <Grid Grid.Row="2" Margin="20,4,20,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,12,0">
                    <TextBlock x:Name="StatusText" TextWrapping="Wrap"
                               Foreground="{StaticResource MutedTextBrush}"/>
                    <ProgressBar x:Name="WorkBar" Height="6" Margin="0,6,0,0"
                                 IsIndeterminate="True" Visibility="Collapsed"/>
                </StackPanel>
                <Button Grid.Column="1" Content="Close" Width="110" Height="32"
                        FontWeight="SemiBold" Click="Close_Click"/>
            </Grid>
        </Grid>
    </Border>
</Window>
