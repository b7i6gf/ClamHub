<Window x:Class="ClamHub.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:local="clr-namespace:ClamHub"
        Title="ClamHub 1.0.4" Height="710" Width="1068"
        MinHeight="710" MinWidth="1068"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" ResizeMode="CanResize"
        Background="{StaticResource BgBrush}"
        StateChanged="Window_StateChanged"
        Closing="Window_Closing">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="40" ResizeBorderThickness="6"
                            CornerRadius="0" GlassFrameThickness="0"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Border x:Name="WindowRoot" Background="{StaticResource BgBrush}"
            BorderBrush="{StaticResource WindowBorderBrush}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Custom title bar -->
            <Grid Grid.Row="0" Background="{StaticResource TitleBarBrush}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center"
                            Margin="14,0,0,0">
                    <TextBlock Text="ClamHub" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <TextBlock x:Name="TitleVersionText" Text="1.0.4" Margin="8,0,0,0"
                               Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Output console position toggles -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center"
                            Margin="0,0,8,0"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <RadioButton x:Name="ViewBottom" Style="{StaticResource ViewToggleButton}"
                                 GroupName="ConsoleView" Checked="ConsoleView_Checked"
                                 ToolTip="Output docked at the bottom">
                        <Grid Width="16" Height="14">
                            <Rectangle Stroke="{StaticResource TextBrush}" StrokeThickness="1.2"
                                       RadiusX="1.5" RadiusY="1.5" Fill="Transparent"/>
                            <Rectangle Height="4" VerticalAlignment="Bottom" Margin="1.5"
                                       Fill="{StaticResource TextBrush}"/>
                        </Grid>
                    </RadioButton>
                    <RadioButton x:Name="ViewRight" Style="{StaticResource ViewToggleButton}"
                                 GroupName="ConsoleView" Checked="ConsoleView_Checked"
                                 ToolTip="Output docked on the right (window widens)">
                        <Grid Width="16" Height="14">
                            <Rectangle Stroke="{StaticResource TextBrush}" StrokeThickness="1.2"
                                       RadiusX="1.5" RadiusY="1.5" Fill="Transparent"/>
                            <Rectangle Width="5" HorizontalAlignment="Right" Margin="1.5"
                                       Fill="{StaticResource TextBrush}"/>
                        </Grid>
                    </RadioButton>
                    <RadioButton x:Name="ViewWindow" Style="{StaticResource ViewToggleButton}"
                                 GroupName="ConsoleView" Checked="ConsoleView_Checked"
                                 ToolTip="Pop-out output window">
                        <Grid Width="16" Height="14">
                            <Rectangle Width="11" Height="9" HorizontalAlignment="Left"
                                       VerticalAlignment="Top" Stroke="{StaticResource TextBrush}"
                                       StrokeThickness="1.2" Fill="Transparent"/>
                            <Rectangle Width="9" Height="7" HorizontalAlignment="Right"
                                       VerticalAlignment="Bottom" Stroke="{StaticResource TitleBarBrush}"
                                       StrokeThickness="2" Fill="{StaticResource TitleBarBrush}"/>
                            <Rectangle Width="9" Height="7" HorizontalAlignment="Right"
                                       VerticalAlignment="Bottom" Stroke="{StaticResource TextBrush}"
                                       StrokeThickness="1.2" Fill="Transparent"/>
                        </Grid>
                    </RadioButton>
                </StackPanel>

                <!-- Detections + About -->
                <StackPanel Grid.Column="2" Orientation="Horizontal"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button x:Name="DetectionsButton" Style="{StaticResource TitleBarTextButton}"
                            Click="Detections_Click"
                            ToolTip="Infected files reported by scans, to work through">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Detections" VerticalAlignment="Center"/>
                            <Ellipse x:Name="DetectionsDot" Width="7" Height="7" Margin="7,1,0,0"
                                     VerticalAlignment="Center" Fill="{StaticResource WarnBrush}"
                                     Visibility="Collapsed"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource TitleBarTextButton}"
                            Click="About_Click"
                            ToolTip="App info; the dot means a ClamHub or ClamAV update is available">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="About" VerticalAlignment="Center"/>
                            <Ellipse x:Name="AboutDot" Width="7" Height="7" Margin="7,1,0,0"
                                     VerticalAlignment="Center" Fill="{StaticResource WarnBrush}"
                                     Visibility="Collapsed"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Window control buttons -->
                <StackPanel Grid.Column="3" Orientation="Horizontal"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Style="{StaticResource CaptionButton}" Click="Minimize_Click" ToolTip="Minimize">
                        <Rectangle Width="11" Height="1" Fill="{StaticResource TextBrush}"/>
                    </Button>
                    <Button x:Name="MaxRestoreButton" Style="{StaticResource CaptionButton}"
                            Click="MaxRestore_Click" ToolTip="Maximize">
                        <Grid Width="11" Height="11">
                            <Rectangle x:Name="MaximizeGlyph" Stroke="{StaticResource TextBrush}"
                                       StrokeThickness="1" Fill="Transparent"/>
                            <Grid x:Name="RestoreGlyph" Visibility="Collapsed">
                                <Rectangle Width="8" Height="8" HorizontalAlignment="Right"
                                           VerticalAlignment="Top" Stroke="{StaticResource TextBrush}"
                                           StrokeThickness="1" Fill="Transparent"/>
                                <Rectangle Width="8" Height="8" HorizontalAlignment="Left"
                                           VerticalAlignment="Bottom" Stroke="{StaticResource TitleBarBrush}"
                                           StrokeThickness="1" Fill="{StaticResource TitleBarBrush}"/>
                                <Rectangle Width="8" Height="8" HorizontalAlignment="Left"
                                           VerticalAlignment="Bottom" Stroke="{StaticResource TextBrush}"
                                           StrokeThickness="1" Fill="Transparent"/>
                            </Grid>
                        </Grid>
                    </Button>
                    <Button Style="{StaticResource CloseCaptionButton}" Click="Close_Click" ToolTip="Close">
                        <Path Data="M0,0 L10,10 M0,10 L10,0" Stroke="{StaticResource TextBrush}"
                              StrokeThickness="1"/>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Main content. Column 1 / Row 2 host the console when docked
                 right / bottom; both collapse to zero otherwise. The layout is
                 driven by ApplyConsoleLayout in code. -->
            <Grid x:Name="RootGrid" Grid.Row="1" Margin="20,8,20,20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="MainColumn" Width="*"/>
            <ColumnDefinition x:Name="ConsoleColumn" Width="0"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition x:Name="MainRow" Height="*"/>
            <RowDefinition x:Name="ConsoleRow" Height="0"/>
        </Grid.RowDefinitions>

        <!-- Header: app name on the left, daemon status and controls on the right -->
        <Grid Grid.Row="0" Grid.Column="0" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="ClamHub" FontSize="26" FontWeight="SemiBold"
                       VerticalAlignment="Center"/>
            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                <Ellipse x:Name="DaemonDot" Width="12" Height="12" Margin="0,1,8,0"
                         Fill="{StaticResource MutedTextBrush}" VerticalAlignment="Center"/>
                <TextBlock x:Name="DaemonStatusText" Text="Daemon status: checking..."
                           FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"
                           Margin="0,0,16,0"/>
                <Button x:Name="StartDaemonButton" Content="Start Daemon" Width="108" Height="30"
                        Margin="0,0,8,0" Click="StartDaemon_Click"/>
                <Button x:Name="StopDaemonButton" Content="Stop Daemon" Width="108" Height="30"
                        Click="StopDaemon_Click"/>
                <Button x:Name="DaemonUpdateButton" Content="Update Signatures" Width="140" Height="30"
                        Margin="8,0,0,0" Click="Update_Click"
                        ToolTip="Download the latest signature databases (freshclam)"/>
            </StackPanel>
        </Grid>

        <!-- Main area: the tab card. Fills the available space; the console
             docks below or to the right. -->
        <Grid Grid.Row="1" Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition x:Name="TabCardRow" Height="*"/>
            </Grid.RowDefinitions>

            <!-- Tabs: Scan and File-Verifier -->
            <Border Grid.Row="0" Background="{StaticResource PanelBrush}" CornerRadius="8"
                    Padding="16,10,16,14" MinHeight="250">
            <Grid>
                <!-- Caption sits right-aligned in the tab header row and follows
                     the selected tab (updated in Tabs_SelectionChanged) -->
                <TextBlock x:Name="TabCaption" Style="{StaticResource PanelCaption}"
                           Text="A N T I V I R U S" VerticalAlignment="Top"
                           Margin="0,11,2,0"/>
                <local:KeepAliveTabControl x:Name="MainTabs" SelectionChanged="Tabs_SelectionChanged">

                <!-- Scan tab -->
                <TabItem Header="Scan">
                    <Grid Margin="0,12,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Profile row (first) -->
                        <Grid Grid.Row="0" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Profile:" VerticalAlignment="Center"
                                       Margin="0,0,10,0" FontWeight="SemiBold"/>
                            <ComboBox Grid.Column="1" x:Name="ProfileCombo" Height="28"
                                      SelectionChanged="ProfileCombo_SelectionChanged"
                                      ToolTip="Selecting a profile fills the scan fields below"/>
                            <Grid Grid.Column="2" Margin="10,0,0,0">
                                <TextBox x:Name="ProfileNameBox" Width="160" Height="28"
                                         MaxLength="16" VerticalContentAlignment="Center"/>
                                <TextBlock Style="{StaticResource PlaceholderText}"
                                           Text="new profile name">
                                    <TextBlock.Visibility>
                                        <Binding ElementName="ProfileNameBox" Path="Text.IsEmpty">
                                            <Binding.Converter>
                                                <BooleanToVisibilityConverter/>
                                            </Binding.Converter>
                                        </Binding>
                                    </TextBlock.Visibility>
                                </TextBlock>
                            </Grid>
                            <Button Grid.Column="3" Content="Save" Width="70" Height="28"
                                    Margin="8,0,0,0" Click="SaveProfile_Click"
                                    ToolTip="Saves the current scan fields under the entered name, or overwrites the selected profile when the name field is empty"/>
                            <Button Grid.Column="4" Content="Delete" Width="70" Height="28"
                                    Margin="8,0,0,0" Click="DeleteProfile_Click"
                                    ToolTip="Removes the selected profile"/>
                        </Grid>

                        <!-- Target row -->
                        <Grid Grid.Row="1" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Target:" VerticalAlignment="Center"
                                       Margin="0,0,10,0" FontWeight="SemiBold"/>
                            <Grid Grid.Column="1">
                                <TextBox x:Name="TargetBox" Height="30"
                                         VerticalContentAlignment="Center"
                                         AllowDrop="True"
                                         KeyDown="TargetBox_KeyDown"
                                         PreviewDragOver="PathBox_PreviewDragOver"
                                         PreviewDrop="PathBox_PreviewDrop"/>
                                <TextBlock Style="{StaticResource PlaceholderText}"
                                           Text="Drop a file/folder here, or enter a path, e.g. C:\Users\Me\Downloads or C:\">
                                    <TextBlock.Visibility>
                                        <Binding ElementName="TargetBox" Path="Text.IsEmpty">
                                            <Binding.Converter>
                                                <BooleanToVisibilityConverter/>
                                            </Binding.Converter>
                                        </Binding>
                                    </TextBlock.Visibility>
                                </TextBlock>
                            </Grid>
                            <Button Grid.Column="2" Style="{StaticResource GlyphButton}"
                                    Width="32" Height="30" Margin="6,0,0,0"
                                    Click="ClearTextBox_Click" Tag="{Binding ElementName=TargetBox}"
                                    ToolTip="Clear the target">
                                <Path Data="M0,0 L10,10 M0,10 L10,0"
                                      Stroke="{StaticResource DangerBrush}" StrokeThickness="1.8"/>
                            </Button>
                            <Button Grid.Column="3" x:Name="ScanBrowseButton" Content="File..." Width="70" Height="30"
                                    Margin="8,0,0,0" Click="ScanBrowse_Click"
                                    ToolTip="Choose one or more files, or a folder, to scan"/>
                            <Button Grid.Column="4" x:Name="QueueButton" Content="Queue..." Width="90" Height="30"
                                    Margin="8,0,0,0" Click="ScanQueue_Click"
                                    ToolTip="Open the scan queue to manage queued targets and saved queues"/>
                            <Button Grid.Column="5" Style="{StaticResource GlyphButton}"
                                    Width="32" Height="30" Margin="8,0,0,0"
                                    Click="SendScanTargetsToVerifier_Click"
                                    ToolTip="Send the Target path and all queued files to the File-Verifier (folders and drives are skipped)">
                                <Path Data="M0,5 L10,5 M6,1 L10,5 L6,9"
                                      Stroke="{StaticResource TextBrush}" StrokeThickness="1.8"/>
                            </Button>
                            <Popup x:Name="ScanBrowsePopup" PlacementTarget="{Binding ElementName=ScanBrowseButton}"
                                   Placement="Bottom" StaysOpen="False" AllowsTransparency="True">
                                <Border Background="{StaticResource PanelBrush}" BorderBrush="#FF55585F"
                                        BorderThickness="1" CornerRadius="4" Padding="4" Margin="0,2,0,0">
                                    <StackPanel MinWidth="150">
                                        <Button Content="Choose Files..." Height="28" Margin="0,0,0,4"
                                                Click="ScanChooseFiles_Click"/>
                                        <Button Content="Choose Folder..." Height="28"
                                                Click="ScanChooseFolder_Click"/>
                                    </StackPanel>
                                </Border>
                            </Popup>
                        </Grid>

                        <!-- Combined row -->
                        <Grid Grid.Row="2" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Only extensions -->
                            <TextBlock Grid.Column="0"
                                       Text="Only extensions:"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"
                                       ToolTip="Optional, forces clamscan instead of the daemon"/>

                            <Grid Grid.Column="1">
                                <TextBox x:Name="ExtensionsBox"
                                         Width="150"
                                         Height="28"
                                         VerticalContentAlignment="Center"/>

                                <TextBlock Style="{StaticResource PlaceholderText}"
                                           Text="e.g. exe dll sys">
                                    <TextBlock.Visibility>
                                        <Binding ElementName="ExtensionsBox" Path="Text.IsEmpty">
                                            <Binding.Converter>
                                                <BooleanToVisibilityConverter/>
                                            </Binding.Converter>
                                        </Binding>
                                    </TextBlock.Visibility>
                                </TextBlock>
                            </Grid>

                            <Button Grid.Column="2"
                                    Content="Exclusions"
                                    Height="28"
                                    Margin="8,0,0,0"
                                    Click="Exclusions_Click"
                                    ToolTip="Exclude files, folders and extensions from scans (standalone clamscan)"/>

                            <!-- spacer pushes action to the right -->
                            <TextBlock Grid.Column="3"/>

                            <!-- Action -->
                            <TextBlock Grid.Column="4"
                                       Text="Action:"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"/>

                            <ComboBox Grid.Column="5"
                                      x:Name="ActionCombo"
                                      Width="130"
                                      Height="28"
                                      SelectedIndex="0">
                                <ComboBoxItem Content="Report only"/>
                                <ComboBoxItem Content="Quarantine"/>
                                <ComboBoxItem Content="Remove"/>
                            </ComboBox>
                        </Grid>

                        <!-- Running scan indicator: pulsing bar plus status text -->
                        <StackPanel Grid.Row="5" x:Name="ScanIndicator" Visibility="Collapsed"
                                    Margin="0,0,0,10">
                            <ProgressBar IsIndeterminate="True"/>
                            <TextBlock x:Name="ScanIndicatorText" Text="Scan running..."
                                       Foreground="{StaticResource AccentBrush}"
                                       FontWeight="SemiBold" Margin="0,5,0,0"/>
                        </StackPanel>

                        <!-- Scan buttons pinned to the bottom of the card so they
                             line up with the File-Verifier inspect button -->
                        <Grid Grid.Row="6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                <Button x:Name="MemoryScanButton" Content="Memory Scan"
                                        Width="120" Height="30" Click="MemoryScan_Click"/>
                                <CheckBox x:Name="KillProcessesCheck" Content="Stop Infected Processes"
                                          Style="{StaticResource PillCheckBox}"
                                          Margin="10,0,0,0"
                                          ToolTip="Memory scan only: --kill --unload"/>
                            </StackPanel>

                            <TextBlock Grid.Column="2" x:Name="InfectedCountText"
                                       VerticalAlignment="Center" Margin="0,0,20,0"
                                       FontWeight="SemiBold"/>
                            <Button Grid.Column="3" x:Name="CancelScanButton" Content="Cancel"
                                    Width="90" Height="30" Margin="0,0,10,0"
                                    IsEnabled="False" Click="CancelScan_Click"/>
                            <Button Grid.Column="4" x:Name="ScanVirusTotalButton" Content="VirusTotal"
                                    Width="120" Height="30" Margin="0,0,10,0" IsEnabled="False"
                                    Click="ScanVirusTotal_Click"
                                    ToolTipService.ShowOnDisabled="True"
                                    ToolTip="Look up the file's SHA256 on VirusTotal. Only the hash is sent, never the file."/>
                            <StackPanel Grid.Column="5" Orientation="Horizontal">
                                <Button x:Name="ScanNoDaemonButton" Content="Scan w/o Daemon"
                                        Width="130" Height="30" Margin="0,0,10,0"
                                        Click="ScanNoDaemon_Click"
                                        ToolTip="Scan with standalone clamscan (never the daemon). Required for per-scan exclusions to take effect."/>
                                <Button x:Name="ScanButton" Content="Start Scan"
                                        Width="120" Height="30" FontWeight="SemiBold"
                                        Click="Scan_Click"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </TabItem>

                <!-- File-Verifier tab: hashes plus file system integrity checks -->
                <TabItem Header="File-Verifier">
                    <Grid Margin="0,12,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- File row -->
                        <Grid Grid.Row="0" Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="File:" VerticalAlignment="Center"
                                       Margin="0,0,10,0" FontWeight="SemiBold"/>
                            <Grid Grid.Column="1">
                                <TextBox x:Name="HashFileBox" Height="30"
                                         VerticalContentAlignment="Center"
                                         AllowDrop="True"
                                         PreviewDragOver="PathBox_PreviewDragOver"
                                         PreviewDrop="PathBox_PreviewDrop"/>
                                <TextBlock Style="{StaticResource PlaceholderText}"
                                           Text="Drop one or more files here, or enter a path, e.g. C:\Downloads\setup.exe">
                                    <TextBlock.Visibility>
                                        <Binding ElementName="HashFileBox" Path="Text.IsEmpty">
                                            <Binding.Converter>
                                                <BooleanToVisibilityConverter/>
                                            </Binding.Converter>
                                        </Binding>
                                    </TextBlock.Visibility>
                                </TextBlock>
                            </Grid>
                            <Button Grid.Column="2" Style="{StaticResource GlyphButton}"
                                    Width="32" Height="30" Margin="6,0,0,0"
                                    Click="ClearVerifierField_Click"
                                    ToolTip="Clear the file. If the field is already empty, clears the verifier queue.">
                                <Path Data="M0,0 L10,10 M0,10 L10,0"
                                      Stroke="{StaticResource DangerBrush}" StrokeThickness="1.8"/>
                            </Button>
                            <Button Grid.Column="3" Content="File..." Width="70" Height="30"
                                    Margin="8,0,0,0" Click="BrowseHashFile_Click"/>
                            <Button Grid.Column="4" x:Name="VerifierQueueButton" Content="Queue..." Width="90" Height="30"
                                    Margin="8,0,0,0" Click="VerifierQueue_Click"
                                    ToolTip="Open the verifier queue to manage queued files and run them all"/>
                        </Grid>

                        <!-- Expected Hash + Hashing Algorithm on one row (Row 1) -->

                        <!-- Checks row: which File-Verifier stages Inspect runs. The
                             selection is persisted in settings.json (InitializeFileVerifierTab
                             restores it, Inspect_Click saves it). File metadata (size,
                             timestamps, attributes) is always included. -->
                        <!-- Running-stage indicator: a single slim bar plus status
                             text that REPLACES the old hash progress bar. It runs
                             determinate during hashing/PE (shows a percentage on
                             large files) and pulsing for the file-system, signature,
                             ClamAV and VirusTotal stages, with a label for each. -->
                        <StackPanel Grid.Row="3" x:Name="VerifierIndicator" Visibility="Collapsed"
                                    Margin="0,0,0,10">
                            <ProgressBar x:Name="VerifierProgressBar" Minimum="0" Maximum="1"/>
                            <TextBlock x:Name="VerifierIndicatorText" Text="Working..."
                                       Foreground="{StaticResource AccentBrush}"
                                       FontWeight="SemiBold" Margin="0,5,0,0"/>
                        </StackPanel>

                        <!-- Expected hash row (now above Algorithm) -->
                        <Grid Grid.Row="1" Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Expected Hash:"
                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <Grid Grid.Column="1">
                                <TextBox x:Name="ExpectedHashBox" Height="28"
                                         VerticalContentAlignment="Center"/>
                                <TextBlock Style="{StaticResource PlaceholderText}"
                                           Text="optional: paste a hash to compare, e.g. 9F86D08...">
                                    <TextBlock.Visibility>
                                        <Binding ElementName="ExpectedHashBox" Path="Text.IsEmpty">
                                            <Binding.Converter>
                                                <BooleanToVisibilityConverter/>
                                            </Binding.Converter>
                                        </Binding>
                                    </TextBlock.Visibility>
                                </TextBlock>
                            </Grid>
                            <Button Grid.Column="2" Style="{StaticResource GlyphButton}"
                                    Width="32" Height="28" Margin="6,0,0,0"
                                    Click="ClearTextBox_Click" Tag="{Binding ElementName=ExpectedHashBox}"
                                    ToolTip="Clear the expected hash">
                                <Path Data="M0,0 L10,10 M0,10 L10,0"
                                      Stroke="{StaticResource DangerBrush}" StrokeThickness="1.8"/>
                            </Button>
                            <TextBlock Grid.Column="3" Text="Hashing Algorithm:" VerticalAlignment="Center"
                                       Margin="16,0,8,0"/>
                            <ComboBox Grid.Column="4" x:Name="HashAlgoCombo" Width="110" Height="28" SelectedIndex="0"
                                      SelectionChanged="HashAlgo_SelectionChanged">
                                <ComboBoxItem Content="All"/>
                                <ComboBoxItem Content="MD5"/>
                                <ComboBoxItem Content="SHA1"/>
                                <ComboBoxItem Content="SHA256"/>
                                <ComboBoxItem Content="SHA384"/>
                                <ComboBoxItem Content="SHA512"/>
                                <ComboBoxItem Content="SHA3-256"/>
                                <ComboBoxItem Content="SHA3-384"/>
                                <ComboBoxItem Content="SHA3-512"/>
                            </ComboBox>
                        </Grid>


                        <!-- Action row: the selectable checks sit on the left at
                             the same height as the buttons, which stay pinned
                             bottom-right. The running-stage indicator is the band
                             directly above this row. -->
                        <Grid Grid.Row="4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Bottom" Margin="0,0,12,0">
                                <!-- Upper line: the network/scan checks -->
                                <WrapPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBlock Text="Scans:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <CheckBox x:Name="IncludeClamAvCheck" Checked="VerifierOption_Changed" Unchecked="VerifierOption_Changed" Content="ClamAV"
                                              Style="{StaticResource PillCheckBox}" Margin="0,0,8,0"
                                              ToolTip="Report-only ClamAV scan (uses the daemon when it runs); findings go to the report and the Detections list, nothing is quarantined."/>
                                    <CheckBox x:Name="IncludeVirusTotalCheck" Checked="VerifierOption_Changed" Unchecked="VerifierOption_Changed" Content="VirusTotal"
                                              Style="{StaticResource PillCheckBox}" Margin="0,0,8,0"
                                              ToolTip="Look up the file's SHA256 on VirusTotal (only the hash is sent, never the file); needs an API key (Settings)."/>
                                </WrapPanel>
                                <!-- Lower line (bottom edge): the local checks -->
                                <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="Checks:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <CheckBox x:Name="IncludeHashesCheck" Checked="VerifierOption_Changed" Unchecked="VerifierOption_Changed" Content="Hashes" IsChecked="True"
                                              Style="{StaticResource PillCheckBox}" Margin="0,0,8,0"
                                              ToolTip="Compute the selected hash algorithm(s) and the file's entropy."/>
                                    <CheckBox x:Name="IncludeFileSystemCheck" Checked="VerifierOption_Changed" Unchecked="VerifierOption_Changed" Content="File System" IsChecked="True"
                                              Style="{StaticResource PillCheckBox}" Margin="0,0,8,0"
                                              ToolTip="Read NTFS owner, access control entries, alternate data streams and the Mark of the Web (Zone.Identifier)."/>
                                    <CheckBox x:Name="IncludePeCheck" Checked="VerifierOption_Changed" Unchecked="VerifierOption_Changed" Content="PE Analysis" IsChecked="True"
                                              Style="{StaticResource PillCheckBox}" Margin="0,0,8,0"
                                              ToolTip="For EXE/DLL/SYS files: headers, imports/imphash, exports, section entropy, security flags (ASLR/DEP/CFG), CLR, overlay and checksum."/>
                                    <CheckBox x:Name="IncludeDocumentCheck" Checked="VerifierOption_Changed" Unchecked="VerifierOption_Changed" Content="Document Analysis" IsChecked="True"
                                              Style="{StaticResource PillCheckBox}" Margin="0,0,8,0"
                                              ToolTip="For Office/PDF/RTF files, shortcuts (LNK), scripts and archives: active-content facts (macros, DDE, remote templates, embedded objects, external URLs, encryption); structure only, not a malware verdict."/>
                                    <CheckBox x:Name="IncludeSignatureCheck" Checked="VerifierOption_Changed" Unchecked="VerifierOption_Changed" Content="Digital Signature" IsChecked="True"
                                              Style="{StaticResource PillCheckBox}" Margin="0,0,8,0"
                                              ToolTip="Verify the Authenticode signature like Windows does: embedded AND catalog signatures; fully offline, revocation is not checked online."/>
                                    <CheckBox x:Name="IncludeStringsCheck" Checked="VerifierOption_Changed" Unchecked="VerifierOption_Changed" Content="Strings/IOCs"
                                              Style="{StaticResource PillCheckBox}"
                                              ToolTip="Extract indicator strings (URLs, registry autostart keys, shell/PowerShell commands); extracted, not validated. Needs PE or Document Analysis enabled."/>
                                </WrapPanel>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right"
                                        VerticalAlignment="Bottom">
                                <Button x:Name="CancelHashButton" Content="Cancel"
                                        Width="90" Height="30" Margin="0,0,10,0"
                                        IsEnabled="False" Click="CancelHash_Click"/>
                                <Button x:Name="InspectButton" Content="Inspect"
                                        Width="100" Height="30" FontWeight="SemiBold"
                                        Click="Inspect_Click"
                                        ToolTip="Run the selected checks on the file. Results go to the console and the History tab."/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </TabItem>

                <!-- Quarantine tab: list of isolated files with restore/delete -->
                <TabItem Header="Quarantine">
                    <Grid Margin="0,12,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="Quarantined files" FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                            <!-- Grouped: view actions | external lookup | file actions.
                                 The 12px margins (double the usual 6) are the visual
                                 separators between the groups. -->
                            <Button Content="Refresh" Height="30" Margin="16,0,0,0"
                                    Click="RefreshQuarantine_Click"/>
                            <Button Content="Open Folder" Height="30" Margin="6,0,0,0"
                                    Click="OpenQuarantineFolder_Click"/>
                            <Button x:Name="QuarantineVtButton" Content="VirusTotal" Height="30"
                                    Margin="24,0,0,0" Click="QuarantineVirusTotal_Click"
                                    ToolTipService.ShowOnDisabled="True"/>
                            <Button Content="Delete Selected" Height="30" Margin="24,0,0,0"
                                    Click="DeleteQuarantine_Click"
                                    ToolTip="Permanently delete the quarantined file"/>
                            <Button Content="Restore Selected" Height="30" Margin="6,0,0,0"
                                    Click="RestoreQuarantine_Click"
                                    ToolTip="Move the file back to its original location"/>
                            <Button Content="Restore + Whitelist" Height="30" Margin="6,0,0,0"
                                    Click="RestoreWhitelistQuarantine_Click"
                                    ToolTip="Restore the file and add it to the whitelist so future scans ignore it (use only for confirmed false positives)"/>
                            <Button Content="Compare With Databanks" Height="30" Margin="6,0,0,0"
                                    Click="CompareWithDatabanks_Click"
                                    ToolTip="Search this threat's signature name across the ClamAV databases to see which of them detect it, and under which names"/>
                        </StackPanel>

                        <ListView Grid.Row="1" x:Name="QuarantineList"
                                  Background="{StaticResource PanelBrush}" BorderThickness="0"
                                  Padding="0"
                                  Foreground="{StaticResource TextBrush}"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                  ScrollViewer.CanContentScroll="False"
                                  ScrollViewer.ScrollChanged="Table_ScrollChanged"
                                  GridViewColumnHeader.Click="QuarantineSort_Click">
                            <ListView.View>
                                <GridView x:Name="QuarantineGridView">
                                    <GridViewColumn Width="200">
                                        <GridViewColumn.Header>
                                            <TextBlock Text="File" Tag="OriginalName"
                                                       ToolTip="Name of the quarantined file."/>
                                        </GridViewColumn.Header>
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding OriginalName}" ToolTip="{Binding OriginalName}"
                                                           Margin="8,0,0,0" TextTrimming="CharacterEllipsis"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Width="220">
                                        <GridViewColumn.Header>
                                            <TextBlock Text="Threat" Tag="Threat"
                                                       ToolTip="The signature name ClamAV reported for this file."/>
                                        </GridViewColumn.Header>
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Threat}" ToolTip="{Binding Threat}"
                                                           Margin="8,0,0,0" TextTrimming="CharacterEllipsis"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Width="140">
                                        <GridViewColumn.Header>
                                            <TextBlock Text="Quarantined" Tag="QuarantinedAt"
                                                       ToolTip="When the file was moved to quarantine."/>
                                        </GridViewColumn.Header>
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding QuarantinedAt, StringFormat='yyyy-MM-dd HH:mm'}"
                                                           ToolTip="{Binding QuarantinedAt, StringFormat='yyyy-MM-dd HH:mm:ss'}"
                                                           Margin="8,0,0,0" TextTrimming="CharacterEllipsis"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Width="260">
                                        <GridViewColumn.Header>
                                            <TextBlock Text="Original location" Tag="OriginalPath"
                                                       ToolTip="Full path the file was scanned from and will be restored to."/>
                                        </GridViewColumn.Header>
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding OriginalPath}" ToolTip="{Binding OriginalPath}"
                                                           Margin="8,0,0,0" TextTrimming="CharacterEllipsis"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                </GridView>
                            </ListView.View>
                        </ListView>

                        <TextBlock Grid.Row="2" x:Name="QuarantineStatus"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   Margin="0,8,0,0"/>
                    </Grid>
                </TabItem>

                <!-- Signatures tab: official DB info + ClamHub's own block/allow lists -->
                <TabItem Header="Signatures">
                    <Grid Margin="0,12,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Header row like the other tabs: label + actions on the left,
                             the add/manage group right-aligned (the gap between the two
                             groups is the visual separator). -->
                        <Grid Grid.Row="0" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                <TextBlock Text="Signature databases" FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                                <Button x:Name="RefreshDbInfoButton" Content="Refresh Info" Height="30"
                                        Margin="16,0,0,0" Click="RefreshDbInfo_Click"/>
                                <Button x:Name="OpenDbFolderButton" Content="Open DB Folder" Height="30"
                                        Margin="6,0,0,0" Click="OpenDbFolder_Click"/>
                                <Button x:Name="SignaturesUpdateButton" Content="Update Signatures" Height="30"
                                        Margin="6,0,0,0" Click="Update_Click"
                                        ToolTip="Download the latest signature databases (freshclam)"/>
                                <Button x:Name="SearchSignaturesButton" Content="Search Signatures" Height="30"
                                        Margin="6,0,0,0" Click="SearchSignatures_Click"
                                        ToolTip="Search or list the signatures inside the databases"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Orientation="Horizontal">
                                <Button x:Name="AddDatabaseButton" Content="Add Database" Height="30"
                                        Margin="0,0,6,0" Click="AddDatabaseFile_Click"
                                        ToolTip="Copy ClamAV database file(s) into the database folder"/>
                                <Button x:Name="AddDatabaseUrlButton" Content="Add From URL" Height="30"
                                        Margin="0,0,6,0" Click="AddDatabaseUrl_Click"
                                        ToolTip="Manage extra databases downloaded from custom URLs (freshclam)"/>
                                <Button x:Name="ManageListsButton" Content="Manage Lists..." Height="30"
                                        FontWeight="SemiBold" Click="ManageSignatureLists_Click"/>
                            </StackPanel>
                        </Grid>

                        <!-- Database table: one row per official DB; selecting a row
                             shows its details in the Signatures console (bottom row). -->
                        <ListView Grid.Row="1" x:Name="SignaturesDbList"
                                  Background="{StaticResource PanelBrush}" BorderThickness="0" Padding="0"
                                  Foreground="{StaticResource TextBrush}"
                                  SelectionMode="Single"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                  ScrollViewer.CanContentScroll="False"
                                  GridViewColumnHeader.Click="SignaturesSort_Click"
                                  ContextMenuOpening="SignaturesDbList_ContextMenuOpening"
                                  SelectionChanged="SignaturesDbList_SelectionChanged"
                                  KeyDown="SignaturesDbList_KeyDown">
                            <ListView.ItemContainerStyle>
                                <!-- Dim the row and add a tooltip for a database disabled for
                                     scanning (the Database cell also shows a "(disabled)"
                                     suffix via DisplayName). BasedOn keeps the app's row style. -->
                                <Style TargetType="ListViewItem" BasedOn="{StaticResource {x:Type ListViewItem}}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Excluded}" Value="True">
                                            <Setter Property="Opacity" Value="0.5"/>
                                            <Setter Property="ToolTip"
                                                    Value="Disabled for scanning: clamd will not load this database, and standalone scans skip it too. Right-click to enable."/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ContextMenu>
                                <ContextMenu Opened="SignaturesContextMenu_Opened">
                                    <MenuItem x:Name="ToggleExcludeMenuItem" Header="Disable database"
                                              Click="ToggleDatabaseExclusion_Click"/>
                                    <MenuItem Header="Remove database" Click="RemoveDatabase_Click"/>
                                </ContextMenu>
                            </ListView.ContextMenu>
                            <ListView.View>
                                <GridView x:Name="SignaturesGridView">
                                    <GridViewColumn Width="175" DisplayMemberBinding="{Binding DisplayName}">
                                        <GridViewColumn.Header>
                                            <TextBlock Text="Database" Tag="FileName"
                                                       ToolTip="Database file name. Click to sort."/>
                                        </GridViewColumn.Header>
                                    </GridViewColumn>
                                    <GridViewColumn Width="115" DisplayMemberBinding="{Binding Version}">
                                        <GridViewColumn.Header>
                                            <TextBlock Text="Version" Tag="Version"
                                                       ToolTip="Database version (containers only). Click to sort."/>
                                        </GridViewColumn.Header>
                                    </GridViewColumn>
                                    <GridViewColumn Width="135" DisplayMemberBinding="{Binding Signatures}">
                                        <GridViewColumn.Header>
                                            <TextBlock Text="Signatures" Tag="Signatures"
                                                       ToolTip="Number of signatures. Click to sort."/>
                                        </GridViewColumn.Header>
                                    </GridViewColumn>
                                    <GridViewColumn Width="205" DisplayMemberBinding="{Binding Built}">
                                        <GridViewColumn.Header>
                                            <TextBlock Text="Built" Tag="Built"
                                                       ToolTip="Build time (containers) or file date. Click to sort."/>
                                        </GridViewColumn.Header>
                                    </GridViewColumn>
                                    <GridViewColumn Width="110" DisplayMemberBinding="{Binding Status}">
                                        <GridViewColumn.Header>
                                            <TextBlock Text="Verified" Tag="Status"
                                                       ToolTip="Signature verification status. Click to sort."/>
                                        </GridViewColumn.Header>
                                    </GridViewColumn>
                                    <GridViewColumn Width="240">
                                        <GridViewColumn.Header>
                                            <TextBlock Text="URL" Tag="Url"
                                                       ToolTip="Custom download URL, if any. Click to sort."/>
                                        </GridViewColumn.Header>
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock TextTrimming="CharacterEllipsis">
                                                    <Hyperlink Click="DatabaseUrl_Click"
                                                               Foreground="{StaticResource AccentBrush}"
                                                               ToolTip="{Binding Url, Mode=OneWay}">
                                                        <!-- Mode=OneWay is REQUIRED: Run.Text binds
                                                             TwoWay by default and Url is read-only;
                                                             a TwoWay binding to a read-only property
                                                             throws during layout and killed the tab. -->
                                                        <Run Text="{Binding Url, Mode=OneWay}"/>
                                                    </Hyperlink>
                                                </TextBlock>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </Grid>
                </TabItem>

                <!-- History tab: table of past actions (its output panel is the
                     HistoryConsoleBorder shown in the bottom row) -->
                <TabItem Header="History">
                    <Grid Margin="0,12,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                <TextBlock Text="Past actions" FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                                <Button Content="Refresh" Height="30" Margin="16,0,0,0"
                                        Click="RefreshHistory_Click"/>
                                <Button Content="Open History File" Height="30" Margin="6,0,0,0"
                                        Click="OpenHistoryFile_Click"
                                        ToolTip="Open Logs\history.json"/>
                                <Button Content="Delete Entry" Height="30" Margin="6,0,0,0"
                                        Click="DeleteHistoryEntry_Click"
                                        ToolTip="Remove the selected scan from the history"/>
                                <Button Content="Clear History" Height="30" Margin="6,0,0,0"
                                        Click="ClearHistory_Click"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button x:Name="ExportHistoryButton" Content="Export" Height="30" Margin="6,0,0,0"
                                        Click="ExportHistoryEntry_Click"
                                        ToolTip="Export the selected entry to a .txt file. Uses the default export folder from Settings."/>
                                <Button x:Name="OpenExportsButton" Content="Open Exports" Height="30" Margin="6,0,0,0"
                                        Click="OpenExportsFolder_Click"
                                        ToolTip="Open the export folder in Windows Explorer."/>
                            </StackPanel>
                        </Grid>

                        <ListView Grid.Row="1" x:Name="HistoryList"
                                  Background="{StaticResource PanelBrush}" BorderThickness="0"
                                  Padding="0"
                                  Foreground="{StaticResource TextBrush}"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                  ScrollViewer.CanContentScroll="False"
                                  ScrollViewer.ScrollChanged="Table_ScrollChanged"
                                  GridViewColumnHeader.Click="HistorySort_Click"
                                  SelectionChanged="HistoryList_SelectionChanged">
                            <ListView.View>
                                <GridView x:Name="HistoryGridView">
                                    <GridViewColumn Width="127">
                                        <GridViewColumn.Header>
                                            <TextBlock Text="Time" Tag="Timestamp"
                                                       ToolTip="Date and time the scan was started."/>
                                        </GridViewColumn.Header>
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Timestamp, StringFormat='yyyy-MM-dd HH:mm'}"
                                                           ToolTip="{Binding Timestamp, StringFormat='yyyy-MM-dd HH:mm:ss'}"
                                                           Margin="8,0,0,0" TextTrimming="CharacterEllipsis"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Width="130">
                                        <GridViewColumn.Header>
                                            <TextBlock Text="Kind" Tag="Kind"
                                                       ToolTip="What was scanned: a file/folder, a whole drive, or memory."/>
                                        </GridViewColumn.Header>
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Kind, Converter={StaticResource TitleCase}}"
                                                           ToolTip="{Binding Kind, Converter={StaticResource TitleCase}}"
                                                           Margin="8,0,0,0" TextTrimming="CharacterEllipsis"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Width="380">
                                        <GridViewColumn.Header>
                                            <TextBlock Text="Target" Tag="Target"
                                                       ToolTip="The scanned path or target."/>
                                        </GridViewColumn.Header>
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Target}" ToolTip="{Binding Target}"
                                                           Margin="8,0,0,0" TextTrimming="CharacterEllipsis"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Width="150">
                                        <GridViewColumn.Header>
                                            <TextBlock Text="Process" Tag="Process"
                                                       ToolTip="The process/executable used (e.g. clamdscan.exe), or VirusTotal for VirusTotal lookups. Empty for hash and quarantine actions."/>
                                        </GridViewColumn.Header>
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Process}" ToolTip="{Binding Process}"
                                                           Margin="8,0,0,0" TextTrimming="CharacterEllipsis"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Width="160">
                                        <GridViewColumn.Header>
                                            <TextBlock Text="Result" Tag="ResultLabel"
                                                       ToolTip="Outcome of the entry (scan result, detections, the action taken, or the hash result)."/>
                                        </GridViewColumn.Header>
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding ResultLabel, Converter={StaticResource TitleCase}}"
                                                           ToolTip="{Binding ResultLabel, Converter={StaticResource TitleCase}}"
                                                           Margin="8,0,0,0" TextTrimming="CharacterEllipsis"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </Grid>
                </TabItem>

                <!-- Settings tab: GUI options plus typed editors for both conf files -->
                <TabItem Header="Settings">
                    <Grid Margin="0,12,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Row="0" Grid.Column="1" Width="1" Background="#FF3A3D46"
                                Margin="14,2,14,2"/>
                        <Border Grid.Row="0" Grid.Column="3" Width="1" Background="#FF3A3D46"
                                Margin="14,2,14,2"/>

                        <!-- Column 1: GUI settings (settings.json) -->
                        <ScrollViewer Grid.Row="0" Grid.Column="0" VerticalScrollBarVisibility="Auto"
                                      Padding="0,0,4,0">
                        <StackPanel>
                            <TextBlock Text="ClamAV folder" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <TextBlock x:Name="ClamAvPathText" TextWrapping="Wrap"
                                       Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,6"
                                       Text="(resolving...)"/>
                            <Button x:Name="ChangeClamAvFolderButton" Content="Change ClamAV Folder..."
                                    Height="30" HorizontalAlignment="Left" Margin="0,0,0,2"
                                    Click="ChangeClamAvFolder_Click"
                                    ToolTip="Select an existing ClamAV folder on this PC; its location is used and saved"/>
                            <Border Height="1" Background="#FF3A3D46" Margin="0,12,0,12"/>

                            <TextBlock Text="GUI behavior  (settings.json)" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <CheckBox x:Name="SetAutoStart" Content="Start daemon on startup" Margin="0,4"
                                      ToolTip="Start the clamd daemon in the background when ClamHub launches (independent of the scan setting)."/>
                            <CheckBox x:Name="SetUpdateOnStart" Content="Update signatures on startup" Margin="0,4"
                                      ToolTip="Run freshclam to update virus definitions each time ClamHub starts."/>
                            <CheckBox x:Name="SetSound" Content="Sound on detection" Margin="0,4"
                                      ToolTip="Play a short sound when a scan finds an infected file."/>
                            <CheckBox x:Name="SetCountFiles" Content="Count scanned files (daemon)"
                                      Margin="0,4"
                                      ToolTip="Counts files in the target after a daemon scan; clamdscan does not report this. Runs in the background."/>
                            <CheckBox x:Name="SetMultiScan" Content="Multi-threaded scans by default" Margin="0,4"
                                      ToolTip="Pass --multiscan so scans use multiple CPU threads."/>
                            <CheckBox x:Name="SetAlwaysAdmin" Content="Always start as admin" Margin="0,4"
                                      ToolTip="Relaunch elevated on startup (asks via UAC). If declined, starts normally."/>
                            <CheckBox x:Name="SetCheckUpdates" Content="Search for updates on startup" Margin="0,4"
                                      ToolTip="Check GitHub for ClamHub and ClamAV updates at startup; one console line, and a dot on the About button when an update exists."/>
                            <StackPanel Orientation="Horizontal" Margin="0,10,0,2">
                                <TextBlock Text="Default action:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <ComboBox x:Name="SetDefaultAction" Width="120" Height="26" SelectedIndex="0"
                                          ToolTip="What to do with infected files by default (used unless overridden per scan).">
                                    <ComboBoxItem Content="Report only"/>
                                    <ComboBoxItem Content="Quarantine"/>
                                    <ComboBoxItem Content="Remove"/>
                                </ComboBox>
                            </StackPanel>
                            <TextBlock Text="VirusTotal API key:" Margin="0,12,0,5"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" x:Name="SetVtKey" Height="28"
                                         VerticalContentAlignment="Center" Margin="0,0,2,0"
                                         ToolTip="Stored only in the local settings.json"/>
                                <Button Grid.Column="1" x:Name="ClearVtKeyButton"
                                        Style="{StaticResource GlyphButton}"
                                        Width="32" Height="28" Margin="6,0,0,0"
                                        Click="ClearVtKey_Click"
                                        ToolTip="Remove the stored API key">
                                    <Path Data="M0,0 L10,10 M0,10 L10,0"
                                          Stroke="{StaticResource DangerBrush}" StrokeThickness="1.8"/>
                                </Button>
                            </Grid>
                            <TextBlock TextWrapping="Wrap" Margin="0,5,0,0" FontSize="11"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       Text="Stored unencrypted in settings.json next to the app (portable). Anyone with access to this folder can read it."/>

                            <Separator Margin="0,12,0,8" Background="#FF3A3D46"/>
                            <TextBlock Text="History export" FontWeight="SemiBold" Margin="0,4,0,2"/>
                            <TextBlock Text="Default folder for the History tab's Export button (one entry to a .txt file)."
                                       Foreground="{StaticResource MutedTextBrush}"
                                       TextWrapping="Wrap" Margin="0,0,0,6"/>
                            <TextBlock x:Name="HistoryExportPathText" TextWrapping="Wrap"
                                       Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,6"
                                       Text="(resolving...)"/>
                            <Button x:Name="ChangeHistoryExportFolderButton" Content="Change Export Folder..."
                                    Height="30" HorizontalAlignment="Left" Margin="0,0,0,6"
                                    Click="ChangeHistoryExportFolder_Click"
                                    ToolTip="Pick the default folder for History exports."/>
                            <CheckBox x:Name="SetHistoryAlwaysExport" Content="Always export to this path"
                                      Margin="0,2"
                                      ToolTip="When ticked, Export saves straight to the folder above without asking. When unticked, the save dialog opens there and you can choose another location."/>

                            <Separator Margin="0,12,0,8" Background="#FF3A3D46"/>
                            <TextBlock Text="Windows context menu" FontWeight="SemiBold" Margin="0,4,0,2"/>
                            <TextBlock Text="Tick the entries to add to the right-click menu of files and folders."
                                       Foreground="{StaticResource MutedTextBrush}"
                                       TextWrapping="Wrap" Margin="0,0,0,6"/>

                            <StackPanel x:Name="ContextMenuOptionsPanel">
                                <TextBlock Text="Entries" Opacity="0.7" Margin="0,2,0,4"/>
                                <StackPanel x:Name="ContextActionsPanel"/>

                                <TextBlock Text="Layout (applies with 2 or more entries)"
                                           Opacity="0.7" Margin="0,10,0,4"/>
                                <RadioButton x:Name="SetGroupSubmenu" GroupName="CtxGrouping"
                                             Content="Submenu (cascading ClamHub menu)" Margin="0,4"
                                             ToolTip="Show multiple entries nested under one cascading ClamHub menu"/>
                                <RadioButton x:Name="SetGroupInline" GroupName="CtxGrouping"
                                             Content="Inline grouping (entries listed directly)" Margin="0,4"
                                             ToolTip="Show multiple entries one under another directly in the context menu"/>
                            </StackPanel>

                            <TextBlock x:Name="ContextMenuStatus"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       TextWrapping="Wrap" Margin="0,6,0,0"/>

                            <CheckBox x:Name="SetUseDaemon" Content="Prefer daemon for scans" Margin="0,10,0,2"
                                      ToolTip="Always uses daemon for context menu scans - when off, scans use standalone clamscan. Does not affect other actions."/>

                            <Separator Margin="0,6,0,8" Background="#FF3A3D46"/>
                            <TextBlock Text="Maintenance" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Button Grid.Row="0" Grid.Column="0" x:Name="CheckUpdatesButton" Content="Check For Updates"
                                        Height="30" Margin="0,0,4,8" Click="CheckUpdates_Click"
                                        ToolTip="Check GitHub for the latest ClamHub and ClamAV releases, and download/set up ClamAV"/>
                                <Button Grid.Row="0" Grid.Column="1" x:Name="UpdateButton" Content="Update Signatures"
                                        Height="30" Margin="4,0,0,8" Click="Update_Click"
                                        ToolTip="Run freshclam to update the signature databases"/>

                                <Button Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Content="Rebuild All Configs"
                                        Height="30" Margin="0,0,0,8" Click="RebuildAllConfigs_Click"
                                        ToolTip="Rewrite clamd.conf and freshclam.conf with correct database and log paths (asks whether to keep your settings)"/>

                                <Button Grid.Row="2" Grid.Column="0" Content="Run Diagnostics" Height="30"
                                        Margin="0,0,4,8" Click="RunDiagnostics_Click"
                                        ToolTip="Run clamconf to show engine, build, database and config diagnostics in the console"/>
                                <Button Grid.Row="2" Grid.Column="1" x:Name="RestartButton" Content="Restart" Height="30"
                                        Margin="4,0,0,8" Click="Restart_Click" ToolTip="Relaunch ClamHub"/>

                                <Button Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" x:Name="AdminRestartButton"
                                        Content="Restart As Admin" Height="30" Click="RestartAsAdmin_Click"
                                        ToolTip="Needed for memory scans of system processes and protected folders"/>
                            </Grid>
                        </StackPanel>
                        </ScrollViewer>

                        <!-- Column 2: clamd.conf editor -->
                        <Grid Grid.Row="0" Grid.Column="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" FontWeight="SemiBold" Margin="0,0,0,8"
                                       Text="Daemon  (clamd.conf)"/>
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                                          Padding="0,0,4,0">
                                <StackPanel x:Name="ClamdConfPanel"/>
                            </ScrollViewer>
                            <WrapPanel Grid.Row="2" Margin="0,10,0,0">
                                <Button Content="Save" Width="64" Height="30" Margin="0,0,6,6"
                                        Click="SaveClamdConf_Click"/>
                                <Button Content="Reload" Width="64" Height="30" Margin="0,0,6,6"
                                        Click="ReloadConfEditors_Click"/>
                                <Button Content="Open File" Width="92" Height="30" Margin="0,0,6,6"
                                        Click="OpenConfFile_Click" Tag="clamd"/>
                                <Button Content="Rebuild Config" Width="118" Height="30" Margin="0,0,6,6"
                                        Click="RebuildConfig_Click" Tag="clamd"
                                        ToolTip="Rewrite this file with correct database and log paths (asks whether to keep your settings)"/>
                                <Button Content="Reload Daemon" Width="118" Height="30" Margin="0,0,6,6"
                                        Click="ReloadDaemon_Click"
                                        ToolTip="Restart the running daemon so signature/config changes take effect (safe when it is stopped)"/>
                            </WrapPanel>
                        </Grid>

                        <!-- Column 3: freshclam.conf editor -->
                        <Grid Grid.Row="0" Grid.Column="4">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="Updater  (freshclam.conf)" FontWeight="SemiBold"
                                       Margin="0,0,0,8"/>
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                                          Padding="0,0,4,0">
                                <StackPanel x:Name="FreshConfPanel"/>
                            </ScrollViewer>
                            <WrapPanel Grid.Row="2" Margin="0,10,0,0">
                                <Button Content="Save" Width="64" Height="30" Margin="0,0,6,6"
                                        Click="SaveFreshConf_Click"/>
                                <Button Content="Reload" Width="64" Height="30" Margin="0,0,6,6"
                                        Click="ReloadConfEditors_Click"/>
                                <Button Content="Open File" Width="92" Height="30" Margin="0,0,6,6"
                                        Click="OpenConfFile_Click" Tag="freshclam"/>
                                <Button Content="Rebuild Config" Width="118" Height="30" Margin="0,0,6,6"
                                        Click="RebuildConfig_Click" Tag="freshclam"
                                        ToolTip="Rewrite this file with correct database and log paths (asks whether to keep your settings)"/>
                            </WrapPanel>
                        </Grid>

                        <!-- Save status indicator, single line across the bottom -->
                        <StackPanel Grid.Row="1" Grid.ColumnSpan="5" Orientation="Horizontal"
                                    Margin="0,14,0,0" VerticalAlignment="Center">
                            <Ellipse x:Name="SettingsStatusDot" Width="10" Height="10"
                                     Margin="0,1,8,0" Fill="Transparent"/>
                            <TextBlock x:Name="SettingsStatusText" Text=""
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </TabItem>
            </local:KeepAliveTabControl>
            </Grid>
            </Border>
        </Grid>

        <!-- Live output console. Default placement is bottom (Row 2); code
             moves it to the right column or a separate window per the setting. -->
        <Border Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" x:Name="ConsoleBorder"
                Background="{StaticResource PanelBrush}" CornerRadius="8"
                Padding="12" Margin="0,16,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0" Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Output" FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Content="Open Logs Folder" Height="30" Margin="0,0,6,0"
                                Click="OpenLogsFolder_Click"
                                ToolTip="Show the Logs directory in Explorer"/>
                        <Button Content="Clear Output" Height="30"
                                Click="ClearConsole_Click"/>
                    </StackPanel>
                </Grid>
                <RichTextBox Grid.Row="1" x:Name="ConsoleBox" IsReadOnly="True" IsDocumentEnabled="True"
                             IsUndoEnabled="False"
                             TextOptions.TextFormattingMode="Display" TextOptions.TextRenderingMode="Grayscale"
                             Background="#FF17181C" Foreground="#FFD6D6D6" BorderThickness="0"
                             FontFamily="Consolas" FontSize="12.5" Padding="8"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Disabled">
                    <FlowDocument PagePadding="0"/>
                </RichTextBox>
            </Grid>
        </Border>

        <!-- History tab output: its own PanelBrush card in the bottom row, shown
             only on the History tab (separated from the table card like the main
             console). Holds the selected scan's infected files. -->
        <Border Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" x:Name="HistoryConsoleBorder"
                Background="{StaticResource PanelBrush}" CornerRadius="8"
                Padding="12" Margin="0,16,0,0" Visibility="Collapsed">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Contents" FontWeight="SemiBold" Margin="0,0,0,6"/>
                <RichTextBox Grid.Row="1" x:Name="HistoryDetailBox" IsReadOnly="True" IsDocumentEnabled="True"
                             IsUndoEnabled="False"
                             Background="#FF17181C" Foreground="#FFD6D6D6" BorderThickness="0"
                             FontFamily="Consolas" FontSize="12" Padding="8"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Disabled">
                    <FlowDocument PagePadding="0"/>
                </RichTextBox>
            </Grid>
        </Border>

        <!-- Signatures tab output: its own PanelBrush card in the bottom row, shown
             only on the Signatures tab. Holds the selected database's sigtool details. -->
        <Border Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" x:Name="SignaturesConsoleBorder"
                Background="{StaticResource PanelBrush}" CornerRadius="8"
                Padding="12" Margin="0,16,0,0" Visibility="Collapsed">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Database details" FontWeight="SemiBold" Margin="0,0,0,6"/>
                <RichTextBox Grid.Row="1" x:Name="SignaturesDetailBox" IsReadOnly="True" IsDocumentEnabled="True"
                             IsUndoEnabled="False"
                             Background="#FF17181C" Foreground="#FFD6D6D6" BorderThickness="0"
                             FontFamily="Consolas" FontSize="12" Padding="8"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Disabled">
                    <FlowDocument PagePadding="0"/>
                </RichTextBox>
            </Grid>
        </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
