<Window x:Class="ClamHub.VerifierQueueWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Verifier queue" Height="460" Width="640"
        MinHeight="340" MinWidth="520"
        WindowStartupLocation="CenterOwner" WindowStyle="None" ResizeMode="CanResize"
        Background="{StaticResource BgBrush}">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="36" ResizeBorderThickness="6"
                            CornerRadius="0" GlassFrameThickness="0"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Border BorderBrush="{StaticResource WindowBorderBrush}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Grid Grid.Row="0" Background="{StaticResource TitleBarBrush}">
                <TextBlock Text="Verifier queue" FontWeight="SemiBold"
                           VerticalAlignment="Center" Margin="14,0,0,0"/>
                <Button HorizontalAlignment="Right" Style="{StaticResource CloseCaptionButton}"
                        Click="Close_Click" ToolTip="Close"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Path Data="M0,0 L10,10 M0,10 L10,0" Stroke="{StaticResource TextBrush}"
                          StrokeThickness="1"/>
                </Button>
            </Grid>

            <!-- Body: file list and its buttons -->
            <Grid Grid.Row="1" Margin="20,16,20,8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" TextWrapping="Wrap" Margin="0,0,0,12"
                           Foreground="{StaticResource MutedTextBrush}"
                           Text="Add the files to verify. Close to keep them queued, or Verify all to run them now with the current check selection. Folders cannot be queued. You can also drop files into the list."/>

                <Border Grid.Row="1" Background="{StaticResource PanelBrush}" CornerRadius="6"
                        Padding="2" AllowDrop="True"
                        PreviewDragOver="FileList_DragOver" Drop="FileList_Drop">
                    <ListBox x:Name="FileList" Background="Transparent" BorderThickness="0"
                             Foreground="{StaticResource TextBrush}" SelectionMode="Extended"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"/>
                </Border>

                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0">
                    <Button Content="Add Files..." Height="28" Margin="0,0,6,0"
                            Click="AddFiles_Click"/>
                    <Button Content="Remove Selected" Height="28" Margin="0,0,6,0"
                            Click="RemoveSelected_Click"/>
                    <Button Content="Clear All" Height="28" Click="ClearAll_Click"/>
                </StackPanel>
            </Grid>

            <!-- Footer: count and actions -->
            <Grid Grid.Row="2" Margin="20,4,20,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" x:Name="StatusText" VerticalAlignment="Center"
                           TextWrapping="Wrap" Margin="0,0,12,0"
                           Foreground="{StaticResource MutedTextBrush}"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="Close" Width="90" Height="32" Margin="0,0,10,0"
                            Click="Close_Click"/>
                    <Button x:Name="VerifyAllButton" Content="Verify All" Width="110" Height="32"
                            FontWeight="SemiBold" Click="VerifyAll_Click"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
