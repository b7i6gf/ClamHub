<Window x:Class="ClamHub.ScanQueueWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Scan queue" Height="480" Width="640"
        MinHeight="360" MinWidth="520"
        WindowStartupLocation="CenterOwner" WindowStyle="None" ResizeMode="CanResize"
        Background="{StaticResource BgBrush}">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="36" ResizeBorderThickness="6"
                            CornerRadius="0" GlassFrameThickness="0"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Border BorderBrush="{StaticResource WindowBorderBrush}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Grid Grid.Row="0" Background="{StaticResource TitleBarBrush}">
                <TextBlock Text="Scan queue" FontWeight="SemiBold"
                           VerticalAlignment="Center" Margin="14,0,0,0"/>
                <Button HorizontalAlignment="Right" Style="{StaticResource CloseCaptionButton}"
                        Click="Close_Click" ToolTip="Close"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Path Data="M0,0 L10,10 M0,10 L10,0" Stroke="{StaticResource TextBrush}"
                          StrokeThickness="1"/>
                </Button>
            </Grid>

            <!-- Body: target list and its buttons -->
            <Grid Grid.Row="1" Margin="20,16,20,8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" TextWrapping="Wrap" Margin="0,0,0,12"
                           Foreground="{StaticResource MutedTextBrush}"
                           Text="Add the files and folders to scan. Close to keep them queued, or Start scan to run them now. Save the current list as a named queue to reuse it later. You can also drop files or folders into the list."/>

                <WrapPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12">
                    <TextBlock Text="Saved queues:" VerticalAlignment="Center" Margin="0,0,8,4"/>
                    <ComboBox x:Name="QueueProfileCombo" Width="150" Height="28" Margin="0,0,6,4"
                              SelectionChanged="QueueProfileCombo_SelectionChanged"/>
                    <Button Content="Load" Height="28" Width="58" Margin="0,0,6,4" Click="LoadQueueProfile_Click"/>
                    <Button Content="Delete" Height="28" Width="62" Margin="0,0,16,4" Click="DeleteQueueProfile_Click"/>
                    <Grid Width="130" Margin="0,0,6,4">
                        <TextBox x:Name="QueueProfileNameBox" Height="28" MaxLength="16"
                                 VerticalContentAlignment="Center"
                                 ToolTip="Name to save the current queue under"/>
                        <TextBlock Style="{StaticResource PlaceholderText}" Text="new queue name">
                            <TextBlock.Visibility>
                                <Binding ElementName="QueueProfileNameBox" Path="Text.IsEmpty">
                                    <Binding.Converter>
                                        <BooleanToVisibilityConverter/>
                                    </Binding.Converter>
                                </Binding>
                            </TextBlock.Visibility>
                        </TextBlock>
                    </Grid>
                    <Button Content="Save queue" Height="28" Width="92" Margin="0,0,0,4" Click="SaveQueueProfile_Click"/>
                </WrapPanel>

                <Border Grid.Row="2" Background="{StaticResource PanelBrush}" CornerRadius="6"
                        Padding="2" AllowDrop="True"
                        PreviewDragOver="TargetList_DragOver" Drop="TargetList_Drop">
                    <ListBox x:Name="TargetList" Background="Transparent" BorderThickness="0"
                             Foreground="{StaticResource TextBrush}" SelectionMode="Extended"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"/>
                </Border>

                <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,8,0,0">
                    <Button Content="Add files..." Height="28" Margin="0,0,6,0"
                            Click="AddFiles_Click"/>
                    <Button Content="Add folder..." Height="28" Margin="0,0,6,0"
                            Click="AddFolder_Click"/>
                    <Button Content="Remove selected" Height="28" Margin="0,0,6,0"
                            Click="RemoveSelected_Click"/>
                    <Button Content="Clear all" Height="28" Click="ClearAll_Click"/>
                </StackPanel>
            </Grid>

            <!-- Footer: count and actions -->
            <Grid Grid.Row="2" Margin="20,4,20,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" x:Name="StatusText" VerticalAlignment="Center"
                           TextWrapping="Wrap" Margin="0,0,12,0"
                           Foreground="{StaticResource MutedTextBrush}"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="Close" Width="90" Height="32" Margin="0,0,10,0"
                            Click="Close_Click"/>
                    <Button x:Name="ScanAllButton" Content="Start scan" Width="110" Height="32"
                            FontWeight="SemiBold" Click="ScanAll_Click"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
